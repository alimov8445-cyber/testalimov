APP_NAME="Network Log Monitor"
APP_URL="https://testalimov-production.up.railway.app"
ADMIN_LOGIN="admin"
ADMIN_PASSWORD="replace-with-a-long-random-password"
# Вместо ADMIN_PASSWORD можно использовать password_hash:
# ADMIN_PASSWORD_HASH="$2y$12$..."

# Для Railway Volume рекомендуется /data
DATA_DIR="/data"
GEO_CACHE_TTL="86400"
LOG_MAX_ENTRIES="5000"
IP_GEO_API_URL="https://ipwho.is"
